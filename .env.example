# KeepFlow — First Move service configuration
# Copy to .env and fill in. NEVER commit a real .env.

# --- Server ---
PORT=8080
NODE_ENV=development

# --- Hybrid classifier (optional) ---
# If ANTHROPIC_API_KEY is unset, the service runs deterministic-only:
# keyword classification + curated runbooks, no LLM call. Fully functional,
# just less robust on messy free-text input.
ANTHROPIC_API_KEY=
# Model used for classification / action selection only. Defaults to
# claude-opus-4-8. Set to claude-haiku-4-5 to cut per-call cost.
FIRSTMOVE_MODEL=claude-opus-4-8
# Hard ceiling on model latency before we fall back to deterministic (ms).
FIRSTMOVE_MODEL_TIMEOUT_MS=6000

# --- Idempotency / result cache ---
# Short-lived result store keyed by request/payment id (result only, never
# request contents). TTL in seconds.
RESULT_CACHE_TTL_SECONDS=900

# --- Payments (x402, seller side) ---
# The 402 challenge shape (PAYMENT-REQUIRED header + accepts[]), the X-PAYMENT
# request header, and the facilitator /verify + /settle contract follow the
# public x402 spec. The one binding still to confirm against OKX is the
# FACILITATOR URL/auth for X Layer settlement.
#
# When enabled, the gate FAILS CLOSED: with no facilitator URL configured it
# refuses to serve (never gives away paid calls). Leave disabled for local dev.
PAYMENTS_ENABLED=false
X402_PAY_TO_ADDRESS=
X402_PRICE_USD=$0.20
X402_NETWORK=eip155:196
# Optional ERC-20 settlement token on X Layer; omit to let the facilitator
# resolve the stablecoin from the $-prefixed price.
X402_ASSET=
# OKX x402 facilitator base URL (verify/settle). CONFIRM against OKX docs.
X402_FACILITATOR_URL=
