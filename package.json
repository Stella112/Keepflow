{
  "name": "keepflow-agent",
  "version": "0.7.0",
  "private": true,
  "description": "KeepFlow lifestyle continuity companion for daily routines, incident recovery, academic planning and grounded study support, operational handover, and calendar reminders.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@okxweb3/x402-core": "^0.1.0",
    "@okxweb3/x402-evm": "^0.2.1",
    "@okxweb3/x402-express": "^0.1.1",
    "docx": "^9.5.1",
    "express": "^4.21.2",
    "jszip": "^3.10.1",
    "pdfkit": "^0.17.2",
    "pptxgenjs": "^4.0.1",
    "unpdf": "^1.6.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^24.13.3",
    "@types/pdfkit": "^0.17.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
